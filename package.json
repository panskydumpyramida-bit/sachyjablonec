{
  "name": "bizuterie-chess-backend",
  "version": "1.0.1",
  "description": "Backend API for Bižuterie Jablonec chess club website",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "npx prisma migrate deploy && node src/server.js",
    "maintenance": "node scripts/sync-production-events.js && node scripts/generate_thumbnails.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node src/utils/seed.js",
    "sync-games": "node scripts/sync_all_games.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ js/",
    "lint:fix": "eslint --fix src/ js/",
    "format": "prettier --write src/ js/ css/"
  },
  "keywords": [
    "chess",
    "cms",
    "backend"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.2.0",
    "chess.js": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsdom": "^27.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.12",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "resend": "^6.7.0",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.33.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.2",
    "prisma": "^5.7.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  },
  "optionalDependencies": {
    "@emnapi/core": "1.9.2",
    "@emnapi/runtime": "1.9.2"
  }
}
